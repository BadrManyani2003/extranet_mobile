{
  "name": "mobile-server-v2",
  "version": "2.0.0",
  "description": "Backend API for IBS Extranet Mobile",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon --watch src src/index.js",
    "start": "node src/index.js",
    "build": "esbuild src/index.js --bundle --platform=node --target=node18 --outfile=dist/main.js --minify && node -e \"const fs = require('fs'); if (fs.existsSync('.env')) fs.copyFileSync('.env', 'dist/.env')\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "mssql": "^12.5.0",
    "qs": "^6.15.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "esbuild": "^0.25.0",
    "nodemon": "^3.1.0"
  }
}
